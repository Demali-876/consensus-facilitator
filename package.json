{
  "name": "consensus-facilitator",
  "version": "0.3.0",
  "description": "x402 payment facilitator — ICP, EVM (mainnet + Base + testnets), SVM (mainnet + devnet)",
  "type": "module",
  "scripts": {
    "install:force": "npm install --force",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop consensus-facilitator",
    "pm2:restart": "pm2 restart consensus-facilitator",
    "pm2:reload": "pm2 reload consensus-facilitator",
    "pm2:logs": "pm2 logs consensus-facilitator",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@dfinity/identity": "^3.4.3",
    "@dfinity/identity-secp256k1": "^3.4.3",
    "@dfinity/principal": "^3.4.3",
    "@icp-sdk/core": "^4.2.3",
    "@ldclabs/ic-auth": "^0.4.0",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.6.1",
    "@scure/base": "^2.0.0",
    "@solana/kit": "^6.1.0",
    "@x402/core": "^2.4.0",
    "@x402/evm": "^2.4.0",
    "@x402/extensions": "^2.4.0",
    "@x402/svm": "^2.4.0",
    "better-sqlite3": "^11.0.0",
    "cborg": "^4.2.0",
    "fastify": "^5.2.0",
    "viem": "^2.46.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "pm2": "^6.0.14",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
